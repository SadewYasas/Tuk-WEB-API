          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/tuk-tuks/filter/province/Western",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "tuk-tuks", "filter", "province", "Western"]
