      ]
    },
    {
      "name": "Real-Time Tracking",
      "item": [
        {
          "name": "Update Tuk-Tuk Location",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": 6.9275,\n  \"longitude\": 80.7795,\n  \"speed\": 45,\n  \"accuracy\": 5\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/tuk-tuks/{{tuk_tuk_id}}/update-location",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "tuk-tuks", "{{tuk_tuk_id}}", "update-location"]
            }
          }
        },
        {
          "name": "Get Movement History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/tuk-tuks/{{tuk_tuk_id}}/movement-history?startDate=2026-04-20&endDate=2026-04-25",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "tuk-tuks", "{{tuk_tuk_id}}", "movement-history"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-04-20"
                },
                {
                  "key": "endDate",
                  "value": "2026-04-25"
                }
              ]
            }
          }
        }
      ]
    }
