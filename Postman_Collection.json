              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/tuk-tuks/filter/district/Colombo",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "tuk-tuks", "filter", "district", "Colombo"]
